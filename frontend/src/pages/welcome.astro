        } catch(e) { console.error(e); }
    };

    async function loadClientes() {
        try {
            const res = await fetch(`${API_URL}/api/clients`, { headers: { 'Authorization': `Bearer ${token}` } });
            cache.clientes = await res.json();
            renderClientesTable(cache.clientes);
        } catch(e) { console.error(e); }
    }

    window.filterClientes = () => {
        const query = document.getElementById('clientSearchInput').value.toLowerCase();
        const filtered = cache.clientes.filter(c => 
            (c.nombre && c.nombre.toLowerCase().includes(query)) || 
            (c.telefono && c.telefono.includes(query))
        );
        renderClientesTable(filtered);
    };

    function renderClientesTable(data) {
        document.getElementById('clientesTableBody').innerHTML = data.map(c => `
