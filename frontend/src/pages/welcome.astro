         ownerSearchInput.addEventListener('input', () => {
             const q = ownerSearchInput.value.toLowerCase().trim();
             if (q.length === 0) { ownerResultsDiv.classList.add('hidden'); return; }
             const matches = ownerSearchData.filter(d => d.searchText.includes(q)).slice(0, 15);
             if (matches.length === 0) {
                 ownerResultsDiv.innerHTML = '<div class="px-4 py-3 text-gray-500 text-sm">Sin resultados</div>';
             } else {
                 ownerResultsDiv.innerHTML = matches.map(d => `
                     <div class="px-4 py-2.5 hover:bg-white/10 cursor-pointer transition-colors border-b border-white/5 last:border-b-0"
