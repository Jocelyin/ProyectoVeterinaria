    window.rescheduleCita = async (citaId) => {
        const input = document.getElementById('rescheduleDateTime');
        if (!input || !input.value) {
            alert('Selecciona una fecha y hora valida');
            return;
        }
        const newDate = new Date(input.value);
        if (isNaN(newDate.getTime())) {
            alert('Fecha invalida');
            return;
        }
        try {
            const res = await fetch(`${API_URL}/api/citas/${citaId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ fecha_hora: newDate.toISOString(), estado: 'pendiente', motivo: `Reprogramada al ${newDate.toLocaleDateString('es-MX', { weekday:'long', day:'numeric', month:'long' })} a las ${newDate.toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit' })}` })
            });
            if (res.ok) {
                closeModal();
                calWeekStart = getMonday(newDate);
                await initCalendar();
            } else {
                const data = await res.json().catch(() => ({}));
                alert(data.detail || 'Error al reprogramar cita');
            }
        } catch(e) { console.error(e); alert('Error de conexion'); }
    };

    window.deleteCita = async (citaId) => {
        if (!confirm('¿Eliminar esta cita?')) return;
        try {
            const res = await fetch(`${API_URL}/api/citas/${citaId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.ok) { closeModal(); await initCalendar(); }
