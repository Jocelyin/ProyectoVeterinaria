                     </div>
                 `).join('');
             }
             ownerResultsDiv.classList.remove('hidden');
         });

         ownerSearchInput.addEventListener('focus', () => {
             if (ownerSearchInput.value.length > 0) ownerResultsDiv.classList.remove('hidden');
         });

