                <button onclick="cancelCitaWithReason(${citaId})" class="flex-1 bg-orange-600 hover:bg-orange-700 text-white py-2.5 rounded-lg text-sm font-bold transition-colors shadow-lg shadow-orange-500/20">Confirmar Cancelación</button>
            </div>
