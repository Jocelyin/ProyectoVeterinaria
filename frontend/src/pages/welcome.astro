    window.cancelCitaWithReason = async (citaId) => {
        const reason = document.getElementById('cancelReasonText')?.value?.trim() || 'Sin motivo';
        try {
            const res = await fetch(`${API_URL}/api/citas/${citaId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ estado: 'cancelada', motivo: reason })
            });
            if (res.ok) { closeModal(); await initCalendar(); }
