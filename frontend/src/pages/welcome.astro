            fechaRegistro: '2026-01-20'
        }
    ];

    // Motivos que atiende un veterinario general
    const MOTIVOS_GENERALES = [
        'Chequeo general',
        'Vacunación',
        'Desparasitación',
        'Control de embarazo'
    ];
    // Todo lo demás (Cirugía, Consulta dermatológica, Urgencia, otro) → especialista

    // --- Horario de la veterinaria ---
    // 0=Domingo, 1=Lunes, ..., 6=Sábado
    const HORARIO_VETERINARIA = {
        0: null,                       // Domingo: cerrado
        1: { inicio: 9, fin: 21 },   // Lunes
        2: { inicio: 9, fin: 21 },   // Martes
        3: { inicio: 9, fin: 21 },   // Miércoles
        4: { inicio: 9, fin: 21 },   // Jueves
        5: { inicio: 9, fin: 21 },   // Viernes
        6: { inicio: 9, fin: 21 },   // Sábado
    };

    const DIAS_SEMANA = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];

    // Valida si la fecha/hora seleccionada cae dentro del horario de la veterinaria
    window.validateBusinessHours = (dateTimeStr) => {
        const warningEl = document.getElementById('businessHoursWarning');
        if (!warningEl) return true;

        if (!dateTimeStr) {
            warningEl.classList.add('hidden');
            return true;
        }

        const dt = new Date(dateTimeStr);
        if (isNaN(dt)) { warningEl.classList.add('hidden'); return true; }

        const dayOfWeek = dt.getDay(); // 0=Dom
        const hour = dt.getHours();
        const horario = HORARIO_VETERINARIA[dayOfWeek];
        const diaNombre = DIAS_SEMANA[dayOfWeek];

        if (!horario) {
            // Día cerrado (domingo)
            warningEl.innerHTML = `<span class="text-lg">🚫</span> <span><strong>${diaNombre}:</strong> La veterinaria está cerrada. Elige otro día.</span>`;
            warningEl.classList.remove('hidden');
            return false;
        }

        if (hour < horario.inicio || hour >= horario.fin) {
            // Fuera de horario
            warningEl.innerHTML = `<span class="text-lg">⏰</span> <span><strong>${diaNombre}:</strong> El horario es de ${horario.inicio}:00 a ${horario.fin}:00 hrs. La hora seleccionada está fuera del horario.</span>`;
            warningEl.classList.remove('hidden');
            return false;
        }

        // Válido
        warningEl.classList.add('hidden');
        return true;
    };

    // Genera los slots de tiempo disponibles para una fecha dada
    window.generateTimeSlots = (dateStr) => {
        const container = document.getElementById('timeSlotsContainer');
        const noSlotsMsg = document.getElementById('noSlotsMsg');
        const hiddenFecha = document.getElementById('citaFecha');

        // Reset selection
        if (hiddenFecha) hiddenFecha.value = '';
        const selectedSlotEl = document.getElementById('citaSelectedSlot');
        if (selectedSlotEl) selectedSlotEl.textContent = '';

        if (!container) return;

        if (!dateStr) {
            container.innerHTML = '<p class="text-gray-600 text-xs col-span-4">Selecciona una fecha para ver los horarios disponibles.</p>';
            if (noSlotsMsg) noSlotsMsg.classList.add('hidden');
            checkVetAvailability('');
            return;
        }

        // dateStr is YYYY-MM-DD — parse as local date
        const [y, m, d] = dateStr.split('-').map(Number);
        const dt = new Date(y, m - 1, d);
        const dayOfWeek = dt.getDay(); // 0=Sun
        const horario = HORARIO_VETERINARIA[dayOfWeek];

        if (!horario) {
            // Closed (Sunday)
            container.innerHTML = '<p class="col-span-4 text-center py-4 text-red-400 text-sm font-semibold">🚫 La veterinaria está cerrada los domingos.</p>';
            if (noSlotsMsg) noSlotsMsg.classList.add('hidden');
            checkVetAvailability('');
            return;
        }

        // Build 30-min slots from inicio to fin
        const slots = [];
        for (let h = horario.inicio; h < horario.fin; h++) {
            slots.push({ h, m: 0,  label: `${String(h).padStart(2,'0')}:00` });
            slots.push({ h, m: 30, label: `${String(h).padStart(2,'0')}:30` });
        }

        const optionsHtml = slots.map(s => {
            const pad = (n) => String(n).padStart(2, '0');
            const dtValue = `${dateStr}T${pad(s.h)}:${pad(s.m)}`;
            return `<option value="${dtValue}">${s.label}</option>`;
        }).join('');

        container.innerHTML = `
            <select class="w-full bg-black/20 border border-white/10 rounded-lg px-4 py-2 text-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
                onchange="selectTimeSlot(this.value)">
                <option value="" disabled selected>— Selecciona una hora —</option>
                ${optionsHtml}
            </select>
        `;

        if (noSlotsMsg) noSlotsMsg.classList.add('hidden');
        checkVetAvailability('');
    };

    window.selectTimeSlot = (dtValue) => {
        // Update hidden field
        const hiddenFecha = document.getElementById('citaFecha');
        if (hiddenFecha) hiddenFecha.value = dtValue;

        // Show selected time
        const selectedSlotEl = document.getElementById('citaSelectedSlot');
        if (selectedSlotEl && dtValue) {
            const [, timePart] = dtValue.split('T');
            selectedSlotEl.textContent = `✅ Horario seleccionado: ${timePart}`;
        } else if (selectedSlotEl) {
            selectedSlotEl.textContent = '';
        }

        // Validate business hours & vet availability
        validateBusinessHours(dtValue);
        checkVetAvailability(dtValue);
    };

    // Comprueba si un vet está disponible a la hora dada (turno + descanso)
    function isVetAvailable(vet, hour) {
        if (hour === null) return null; // sin fecha seleccionada
        const turnoInfo = TURNOS[vet.turno];
        if (!turnoInfo) return false;
        // La hora debe caer dentro del turno
        if (hour < turnoInfo.inicio || hour >= turnoInfo.fin) return false;
        // No disponible en su hora de descanso
        if (hour === vet.descanso) return false;
        return true;
    }

    // Recalcula y actualiza la UI de disponibilidad de cada vet card
    window.checkVetAvailability = (dateTimeStr) => {
        const vetCards = document.querySelectorAll('.vet-card');
        if (!vetCards.length) return;

        let selectedHour = null;
        if (dateTimeStr) {
            const dt = new Date(dateTimeStr);
            if (!isNaN(dt)) selectedHour = dt.getHours();
        }

        vetCards.forEach(card => {
            const vetId = parseInt(card.dataset.vetId);
            const vet = VETERINARIOS.find(v => v.id === vetId);
            if (!vet) return;

            const available = isVetAvailable(vet, selectedHour);
            const statusEl = card.querySelector('.vet-status');
            const scheduleEl = card.querySelector('.vet-schedule');

            // Remove old state classes
            card.classList.remove('vet-available', 'vet-unavailable', 'vet-neutral');

            const turnoInfo = TURNOS[vet.turno] || {};
            const turnoLabel = turnoInfo.label || vet.turno;
            const horarioDisplay = `${turnoLabel} (${turnoInfo.inicio || '?'}:00–${turnoInfo.fin || '?'}:00) · Descanso: ${vet.descanso}:00`;

            if (selectedHour === null) {
                // No date selected — neutral
                card.classList.add('vet-neutral');
                card.removeAttribute('disabled');
                card.style.opacity = '1';
                card.style.cursor = 'pointer';
                statusEl.textContent = '';
                statusEl.className = 'vet-status text-xs mt-1';
                if (scheduleEl) scheduleEl.textContent = `🕐 ${horarioDisplay}`;
            } else if (available) {
                card.classList.add('vet-available');
                card.removeAttribute('disabled');
                card.style.opacity = '1';
                card.style.cursor = 'pointer';
                statusEl.textContent = '✅ Disponible';
                statusEl.className = 'vet-status text-xs mt-1 text-emerald-400 font-semibold';
                if (scheduleEl) scheduleEl.textContent = `🕐 ${horarioDisplay}`;
            } else {
                card.classList.add('vet-unavailable');
                card.setAttribute('disabled', 'true');
                card.style.opacity = '0.45';
                card.style.cursor = 'not-allowed';
                statusEl.textContent = selectedHour === vet.descanso ? '☕ En descanso' : '🔒 Fuera de turno';
                statusEl.className = 'vet-status text-xs mt-1 text-red-400';
                if (scheduleEl) scheduleEl.textContent = `🕐 ${horarioDisplay}`;
                // If this card was selected, deselect it
                if (card.classList.contains('vet-selected')) {
                    card.classList.remove('vet-selected');
                    const hiddenVet = document.getElementById('citaDoctorNombre');
                    if (hiddenVet) hiddenVet.value = '';
                }
            }
        });
    };

    window.selectVet = (vetId, nombre) => {
        const vet = VETERINARIOS.find(v => v.id === vetId);
        if (!vet) return;

        // Check if available
        const fechaEl = document.getElementById('citaFecha');
        const dateStr = fechaEl ? fechaEl.value : '';
        let selectedHour = null;
        if (dateStr) { const dt = new Date(dateStr); if (!isNaN(dt)) selectedHour = dt.getHours(); }

        if (selectedHour !== null && !isVetAvailable(vet, selectedHour)) return; // blocked

        document.querySelectorAll('.vet-card').forEach(c => c.classList.remove('vet-selected'));
        const card = document.querySelector(`.vet-card[data-vet-id="${vetId}"]`);
        if (card) card.classList.add('vet-selected');

        const hidden = document.getElementById('citaDoctorNombre');
        if (hidden) hidden.value = nombre;
    };

    // --- Settings Modal ---
    let editingVetId = null;

    // --- Turno/Consultorio helpers ---
    function getTurnoCount(turno, excludeVetId = null) {
        return VETERINARIOS.filter(v => v.turno === turno && v.id !== excludeVetId).length;
    }

    function getOccupiedConsultorios(turno, excludeVetId = null) {
        return VETERINARIOS
            .filter(v => v.turno === turno && v.id !== excludeVetId)
            .map(v => v.consultorio);
    }

    function getAvailableConsultorios(turno, excludeVetId = null) {
        const occupied = getOccupiedConsultorios(turno, excludeVetId);
        return CONSULTORIOS.filter(c => !occupied.includes(c));
    }

    function getUsedDescansos(turno, excludeVetId = null) {
        return VETERINARIOS
            .filter(v => v.turno === turno && v.id !== excludeVetId)
            .map(v => v.descanso);
    }

    function getNextDescanso(turno, excludeVetId = null) {
        const used = getUsedDescansos(turno, excludeVetId);
        const available = TURNOS[turno].descansos.filter(d => !used.includes(d));
        return available.length > 0 ? available[0] : null;
    }

    window.updateConsultorioOptions = () => {
        const turnoSelect = document.getElementById('vetFormTurno');
        const consultorioSelect = document.getElementById('vetFormConsultorio');
        const turnoMsg = document.getElementById('vetFormTurnoMsg');
        const selectedTurno = turnoSelect.value;

        // Reset consultorio
        consultorioSelect.innerHTML = '';

        if (!selectedTurno) {
            consultorioSelect.innerHTML = '<option value="">— Selecciona un turno primero —</option>';
            turnoMsg.classList.add('hidden');
            return;
        }

        // Check capacity
        const count = getTurnoCount(selectedTurno, editingVetId);
        if (count >= MAX_POR_TURNO) {
            turnoMsg.textContent = `⚠️ Este turno ya tiene ${MAX_POR_TURNO} veterinarios. No se pueden agregar más.`;
            turnoMsg.classList.remove('hidden');
            consultorioSelect.innerHTML = '<option value="">— Turno lleno —</option>';
            return;
        }
        turnoMsg.textContent = `${count}/${MAX_POR_TURNO} veterinarios en este turno`;
        turnoMsg.classList.remove('hidden');

        // Populate available consultorios
        const available = getAvailableConsultorios(selectedTurno, editingVetId);
        if (available.length === 0) {
            consultorioSelect.innerHTML = '<option value="">— No hay consultorios disponibles —</option>';
            return;
        }
        consultorioSelect.innerHTML = '<option value="">— Seleccionar consultorio —</option>' +
            available.map(c => `<option value="${c}">Consultorio ${c}</option>`).join('');
    };

    window.openSettingsModal = () => {
        const modal = document.getElementById('settingsModal');
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        loadConfigData();
        switchSettingsTab('general');
    };

    window.closeSettingsModal = () => {
        const modal = document.getElementById('settingsModal');
        modal.classList.add('hidden');
        document.body.style.overflow = '';
    };

    // Close modal when clicking overlay
    document.addEventListener('click', (e) => {
        const modal = document.getElementById('settingsModal');
        if (e.target === modal) {
            closeSettingsModal();
        }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            const modal = document.getElementById('settingsModal');
            if (modal && !modal.classList.contains('hidden')) {
                closeSettingsModal();
            }
        }
    });

    window.switchSettingsTab = (tabName) => {
        // Update sidebar active state
        document.querySelectorAll('.settings-sidebar-item').forEach(item => {
            item.classList.remove('settings-sidebar-active');
        });
        const activeItem = document.querySelector(`.settings-sidebar-item[data-settings-tab="${tabName}"]`);
        if (activeItem) activeItem.classList.add('settings-sidebar-active');

        // Show the right panel
        document.querySelectorAll('.settings-panel').forEach(p => p.classList.add('hidden'));
        if (tabName === 'general') {
            document.getElementById('settingsGeneral').classList.remove('hidden');
        } else if (tabName === 'veterinarios') {
            document.getElementById('settingsVeterinarios').classList.remove('hidden');
            renderVetList();
        } else if (tabName === 'reportes') {
            document.getElementById('settingsReportes').classList.remove('hidden');
        }
    };

    async function loadConfigData() {
        try {
            const res = await fetch(`${API_URL}/api/me`, { headers: { 'Authorization': `Bearer ${token}` } });
            if (res.ok) {
                currentUserData = await res.json();
                document.getElementById('cfgNombreVet').value = currentUserData.nombre_veterinaria || '';
                document.getElementById('cfgDireccion').value = currentUserData.direccion || '';
                document.getElementById('cfgTelefono').value = currentUserData.telefono || '';
                document.getElementById('cfgEmail').value = currentUserData.email || '';
            }
        } catch(e) { console.error(e); }
    }

    window.saveConfig = async () => {
        const statusEl = document.getElementById('cfgStatus');
        try {
            const res = await fetch(`${API_URL}/api/me`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({
                    nombre_veterinaria: document.getElementById('cfgNombreVet').value,
                    direccion: document.getElementById('cfgDireccion').value,
                    telefono: document.getElementById('cfgTelefono').value,
                    email: document.getElementById('cfgEmail').value
                })
            });
            if (res.ok) {
                currentUserData = await res.json();
                statusEl.textContent = 'Cambios guardados correctamente';
                statusEl.className = 'mt-3 text-center text-xs py-2 rounded-lg bg-emerald-500/20 text-emerald-400';
                statusEl.classList.remove('hidden');
                const nameDisplay = document.getElementById('userNameDisplay');
                if (nameDisplay) nameDisplay.textContent = currentUserData.nombre_veterinaria || currentUserData.username;
                setTimeout(() => statusEl.classList.add('hidden'), 3000);
            } else {
                const data = await res.json().catch(() => ({}));
                statusEl.textContent = data.detail || 'Error al guardar';
                statusEl.className = 'mt-3 text-center text-xs py-2 rounded-lg bg-red-500/20 text-red-400';
                statusEl.classList.remove('hidden');
            }
        } catch(e) {
            statusEl.textContent = 'Error de conexion';
            statusEl.className = 'mt-3 text-center text-xs py-2 rounded-lg bg-red-500/20 text-red-400';
            statusEl.classList.remove('hidden');
        }
    };

    // --- Veterinarios CRUD (in-memory) ---
    function formatDate(dateStr) {
        if (!dateStr) return '';
        const d = new Date(dateStr + 'T00:00:00');
        return d.toLocaleDateString('es-MX', { day: '2-digit', month: 'short', year: 'numeric' });
    }

    function renderVetList() {
        const container = document.getElementById('vetListContainer');
        if (!container) return;

        // Update add button state
        const addBtn = document.querySelector('[onclick="openAddVetForm()"]');
        if (addBtn) {
            if (VETERINARIOS.length >= MAX_VETERINARIOS) {
                addBtn.disabled = true;
                addBtn.style.opacity = '0.5';
                addBtn.style.cursor = 'not-allowed';
                addBtn.title = `Máximo ${MAX_VETERINARIOS} veterinarios alcanzado`;
            } else {
                addBtn.disabled = false;
                addBtn.style.opacity = '1';
                addBtn.style.cursor = 'pointer';
                addBtn.title = '';
            }
        }

        if (VETERINARIOS.length === 0) {
            container.innerHTML = '<p class="text-gray-500 text-sm py-6 text-center">No hay veterinarios registrados. Haz clic en "+ Agregar" para crear uno.</p>';
            return;
        }

        // Group by turno
        const matutinos = VETERINARIOS.filter(v => v.turno === 'matutino');
        const vespertinos = VETERINARIOS.filter(v => v.turno === 'vespertino');

        function renderGroup(title, vets, turnoColor) {
            if (vets.length === 0) return '';
            return `
                <div class="mb-4">
                    <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-bold uppercase tracking-wider ${turnoColor}">${title}</span>
                        <span class="text-[10px] text-gray-600">(${vets.length}/${MAX_POR_TURNO})</span>
                    </div>
                    ${vets.map(v => renderVetCard(v)).join('')}
                </div>`;
        }

        container.innerHTML =
            renderGroup('☀️ Turno Matutino (9:00 – 15:00)', matutinos, 'text-amber-400') +
            renderGroup('🌙 Turno Vespertino (15:00 – 21:00)', vespertinos, 'text-indigo-400');
    }

    function renderVetCard(v) {
        const turnoInfo = TURNOS[v.turno] || {};
        const turnoLabel = turnoInfo.label || v.turno;
        return `
            <div class="settings-vet-card">
                <div class="flex items-center gap-4 flex-1 min-w-0">
                    <div class="vet-photo-thumb">
                        ${v.foto ? `<img src="${v.foto}" alt="${v.nombre}" />` : `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>`}
                    </div>
                    <div class="min-w-0 flex-1">
                        <p class="text-white font-semibold text-sm truncate">${v.nombre}</p>
                        <p class="text-emerald-400 text-xs">${v.especialidad}${v.subespecialidad ? ' · ' + v.subespecialidad : ''}</p>
                        <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-1 text-[11px] text-gray-500">
                            <span>📋 Cédula: ${v.cedula || '—'}</span>
                            <span>🏫 ${v.universidad || '—'}</span>
                            <span>📅 ${v.experiencia != null ? v.experiencia + ' años' : '—'}</span>
                            <span>🏥 Consultorio ${v.consultorio || '—'}</span>
                        </div>
                        <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-0.5 text-[11px] text-gray-500">
                            <span>📞 ${v.telefono || '—'}</span>
                            <span>🕐 ${turnoLabel} (${turnoInfo.inicio || '?'}:00–${turnoInfo.fin || '?'}:00)</span>
                            <span>☕ Descanso: ${v.descanso}:00</span>
                            <span>📆 Registro: ${formatDate(v.fechaRegistro)}</span>
                        </div>
                    </div>
                </div>
                <div class="flex items-center gap-2 flex-shrink-0">
                    <button onclick="openEditVetForm(${v.id})" class="settings-btn-icon" title="Editar">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                    </button>
                    <button onclick="deleteVet(${v.id})" class="settings-btn-icon settings-btn-danger" title="Eliminar">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                    </button>
                </div>
            </div>
        `;
    }

    window.openAddVetForm = () => {
        if (VETERINARIOS.length >= MAX_VETERINARIOS) {
            alert(`Se ha alcanzado el máximo de ${MAX_VETERINARIOS} veterinarios registrados.`);
            return;
        }
        editingVetId = null;
        document.getElementById('vetFormTitle').textContent = 'Agregar Veterinario';
        document.getElementById('vetFormNombre').value = '';
        document.getElementById('vetFormEspecialidad').value = '';
        document.getElementById('vetFormSubespecialidad').value = '';
        document.getElementById('vetFormCedula').value = '';
        document.getElementById('vetFormUniversidad').value = '';
        document.getElementById('vetFormExperiencia').value = '';
        document.getElementById('vetFormColegiado').value = '';
        document.getElementById('vetFormTelefono').value = '+52 ';
        document.getElementById('vetFormTurno').value = '';
        document.getElementById('vetFormConsultorio').innerHTML = '<option value="">— Selecciona un turno primero —</option>';
        document.getElementById('vetFormTurnoMsg').classList.add('hidden');
        // Auto-set today's date
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('vetFormFechaRegistro').value = today;
        document.getElementById('vetFormCertList').innerHTML = '';
        document.getElementById('vetFormContainer').classList.remove('hidden');
    };

    window.openEditVetForm = (id) => {
        const vet = VETERINARIOS.find(v => v.id === id);
        if (!vet) return;
        editingVetId = id;
        document.getElementById('vetFormTitle').textContent = 'Editar Veterinario';
        document.getElementById('vetFormNombre').value = vet.nombre;
        document.getElementById('vetFormEspecialidad').value = vet.especialidad;
        document.getElementById('vetFormSubespecialidad').value = vet.subespecialidad || '';
        document.getElementById('vetFormCedula').value = vet.cedula || '';
        document.getElementById('vetFormUniversidad').value = vet.universidad || '';
        document.getElementById('vetFormExperiencia').value = vet.experiencia ?? '';
        document.getElementById('vetFormColegiado').value = vet.colegiado || '';
        document.getElementById('vetFormTelefono').value = vet.telefono || '+52 ';
        // Set turno first, then populate consultorios
        document.getElementById('vetFormTurno').value = vet.turno || '';
        updateConsultorioOptions();
        // Now set the current consultorio value
        document.getElementById('vetFormConsultorio').value = vet.consultorio || '';
        document.getElementById('vetFormFechaRegistro').value = vet.fechaRegistro || '';
        document.getElementById('vetFormCertList').innerHTML = '';
        document.getElementById('vetFormContainer').classList.remove('hidden');
    };

    window.saveVetForm = () => {
        const nombre = document.getElementById('vetFormNombre').value.trim();
        const especialidad = document.getElementById('vetFormEspecialidad').value.trim();
        const subespecialidad = document.getElementById('vetFormSubespecialidad').value.trim();
        const cedula = document.getElementById('vetFormCedula').value.trim();
        const universidad = document.getElementById('vetFormUniversidad').value.trim();
        const experiencia = parseInt(document.getElementById('vetFormExperiencia').value) || 0;
        const colegiado = document.getElementById('vetFormColegiado').value.trim();
        const telefono = document.getElementById('vetFormTelefono').value.trim();
        const turno = document.getElementById('vetFormTurno').value;
        const consultorio = document.getElementById('vetFormConsultorio').value;
        const fechaRegistro = document.getElementById('vetFormFechaRegistro').value.trim();

        if (!nombre || !especialidad) {
            alert('Por favor completa al menos el nombre y la especialidad.');
            return;
        }

        if (!turno) {
            alert('Por favor selecciona un turno (Matutino o Vespertino).');
            return;
        }

        if (!consultorio) {
            alert('Por favor selecciona un consultorio.');
            return;
        }

        // Validate capacity
        const turnoCount = getTurnoCount(turno, editingVetId);
        if (turnoCount >= MAX_POR_TURNO) {
            alert(`El ${TURNOS[turno].label} ya tiene ${MAX_POR_TURNO} veterinarios. No se pueden agregar más.`);
            return;
        }

        // Validate consultorio uniqueness in turno
        const occupied = getOccupiedConsultorios(turno, editingVetId);
        if (occupied.includes(consultorio)) {
            alert(`El Consultorio ${consultorio} ya está ocupado en el ${TURNOS[turno].label}.`);
            return;
        }

        // Auto-assign break hour
        const descanso = getNextDescanso(turno, editingVetId);
        if (descanso === null) {
            alert('No hay horas de descanso disponibles en este turno.');
            return;
        }

        if (editingVetId !== null) {
            const vet = VETERINARIOS.find(v => v.id === editingVetId);
            if (vet) {
                vet.nombre = nombre;
                vet.especialidad = especialidad;
                vet.subespecialidad = subespecialidad;
                vet.cedula = cedula;
                vet.universidad = universidad;
                vet.experiencia = experiencia;
                vet.colegiado = colegiado;
                vet.telefono = telefono;
                vet.turno = turno;
                vet.consultorio = consultorio;
                vet.descanso = descanso;
                // Don't change fechaRegistro on edit
            }
        } else {
            // Check total max
            if (VETERINARIOS.length >= MAX_VETERINARIOS) {
                alert(`Se ha alcanzado el máximo de ${MAX_VETERINARIOS} veterinarios.`);
                return;
            }
            const maxId = VETERINARIOS.length > 0 ? Math.max(...VETERINARIOS.map(v => v.id)) : 0;
            VETERINARIOS.push({
                id: maxId + 1,
                nombre,
                especialidad,
                subespecialidad,
                cedula,
                universidad,
                experiencia,
                colegiado,
                telefono,
                turno,
                consultorio,
                descanso,
                foto: '',
                fechaRegistro: fechaRegistro || new Date().toISOString().split('T')[0]
            });
        }

        cancelVetForm();
        renderVetList();
    };

    window.cancelVetForm = () => {
        editingVetId = null;
        document.getElementById('vetFormContainer').classList.add('hidden');
    };

    window.deleteVet = (id) => {
        if (!confirm('¿Estás seguro de eliminar este veterinario?')) return;
        const idx = VETERINARIOS.findIndex(v => v.id === id);
        if (idx !== -1) VETERINARIOS.splice(idx, 1);
        renderVetList();
    };

    // --- Navigation ---
    window.navigateTo = (viewName) => {
        // Update UI
        views.forEach(v => document.getElementById(v).classList.add('hidden'));
        document.getElementById(`view${viewName.charAt(0).toUpperCase() + viewName.slice(1)}`).classList.remove('hidden');
        
        // Update active tab
        document.querySelectorAll('.nav-tab').forEach(tab => {
            tab.classList.remove('nav-tab-active', 'bg-white/20', 'text-white');
            tab.classList.add('text-white/70', 'hover:text-white', 'hover:bg-white/10');
        });
        const activeTab = document.querySelector(`.nav-tab[data-tab="${viewName}"]`);
        if (activeTab) {
            activeTab.classList.add('nav-tab-active', 'bg-white/20', 'text-white');
            activeTab.classList.remove('text-white/70', 'hover:text-white', 'hover:bg-white/10');
        }

        // Show/hide FAB button
        const fabBtn = document.getElementById('citaFabBtn');
        if (fabBtn) {
            if (viewName === 'citas') fabBtn.style.display = 'flex';
            else {
                fabBtn.style.display = 'none';
                closeCitaDrawer();
            }
        }

        // Update Title & Load Data
        const titleEl = document.getElementById('pageTitle');
        const subtitleEl = document.getElementById('pageSubtitle');
        const actionsEl = document.getElementById('actionButtons');
        actionsEl.innerHTML = ''; // Clear actions

        if (viewName === 'dashboard') {
            titleEl.textContent = 'Panel Principal';
            subtitleEl.textContent = 'Bienvenido a su sistema de gestión';
        } else if (viewName === 'mascotas') {
            titleEl.textContent = 'Gestión de Mascotas';
            subtitleEl.textContent = 'Directorio de pacientes';
            loadMascotas();
        } else if (viewName === 'citas') {
            titleEl.textContent = 'Agenda de Citas';
            subtitleEl.textContent = 'Calendario semanal';
            initCalendar();
        } else if (viewName === 'clientes') {
            titleEl.textContent = 'Gestión de Clientes';
            subtitleEl.textContent = 'Base de datos de propietarios';
            loadClientes();
            actionsEl.innerHTML = `<button onclick="openClientModal()" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg font-bold shadow-lg shadow-emerald-500/20">Nuevo Cliente</button>`;
        } else if (viewName === 'admin') {
            titleEl.textContent = 'Administración del Sistema';
            subtitleEl.textContent = 'Gestión de Veterinarias';
            loadAdminData();
        }
    };

    // --- Cita Drawer Toggle ---
    let citaDrawerOpen = false;

    window.toggleCitaDrawer = (prefillDateTime = null) => {
        if (citaDrawerOpen) {
            closeCitaDrawer();
        } else {
            openCitaDrawer(prefillDateTime);
        }
    };

    function openCitaDrawer(prefillDateTime = null) {
        citaDrawerOpen = true;
        const drawer = document.getElementById('citaDrawer');
        const overlay = document.getElementById('citaDrawerOverlay');
        const fabBtn = document.getElementById('citaFabBtn');
        const fabIcon = document.getElementById('citaFabIcon');

        if (drawer) drawer.style.transform = 'translateX(0)';
        if (overlay) { overlay.style.opacity = '1'; overlay.style.pointerEvents = 'auto'; }
        if (fabBtn) { fabBtn.style.background = 'linear-gradient(135deg, #ef4444, #dc2626)'; fabBtn.style.boxShadow = '0 6px 20px rgba(239,68,68,0.4)'; }
        if (fabIcon) fabIcon.style.transform = 'rotate(45deg)';

        populateCitaDrawerForm(prefillDateTime);
    }

    function closeCitaDrawer() {
        citaDrawerOpen = false;
        const drawer = document.getElementById('citaDrawer');
        const overlay = document.getElementById('citaDrawerOverlay');
        const fabBtn = document.getElementById('citaFabBtn');
        const fabIcon = document.getElementById('citaFabIcon');

        if (drawer) drawer.style.transform = 'translateX(100%)';
        if (overlay) { overlay.style.opacity = '0'; overlay.style.pointerEvents = 'none'; }
        if (fabBtn) { fabBtn.style.background = 'linear-gradient(135deg, #3b82f6, #2563eb)'; fabBtn.style.boxShadow = '0 6px 20px rgba(37,99,235,0.4)'; }
        if (fabIcon) fabIcon.style.transform = 'rotate(0deg)';
    }

    // --- Loaders ---
    async function loadMascotas() {
        try {
            const res = await fetch(`${API_URL}/api/patients`, { headers: { 'Authorization': `Bearer ${token}` } });
            cache.mascotas = await res.json();
            renderMascotasTable(cache.mascotas);
        } catch(e) { console.error(e); }
    }

    // Species definitions for grouping
    const SPECIES_GROUPS = [
        { key: 'Perro', label: 'Perros', icon: '🐕', color: 'amber' },
        { key: 'Gato', label: 'Gatos', icon: '🐱', color: 'blue' },
        { key: 'Ave',  label: 'Aves',  icon: '🐦', color: 'cyan' },
    ];
    const OTHER_GROUP = { key: '__other', label: 'Otros', icon: '🐾', color: 'purple' };

    function renderMascotasTable(data) {
        const container = document.getElementById('mascotasGroupedContainer');

        // Group pets by species
        const groups = {};
        SPECIES_GROUPS.forEach(g => groups[g.key] = []);
        groups[OTHER_GROUP.key] = [];

        data.forEach(m => {
            const matched = SPECIES_GROUPS.find(g => g.key === m.especie);
            if (matched) groups[matched.key].push(m);
            else groups[OTHER_GROUP.key].push(m);
        });

        const allGroups = [...SPECIES_GROUPS, OTHER_GROUP];

        container.innerHTML = allGroups.map(g => {
            const pets = groups[g.key];
            if (pets.length === 0) return ''; // skip empty groups
            const colorMap = {
                amber:  { bg: 'bg-amber-500/15',  border: 'border-amber-500/30',  text: 'text-amber-400',  hdr: 'from-amber-600/80 to-amber-700/80' },
                blue:   { bg: 'bg-blue-500/15',   border: 'border-blue-500/30',   text: 'text-blue-400',   hdr: 'from-blue-600/80 to-blue-700/80' },
                cyan:   { bg: 'bg-cyan-500/15',   border: 'border-cyan-500/30',   text: 'text-cyan-400',   hdr: 'from-cyan-600/80 to-cyan-700/80' },
                purple: { bg: 'bg-purple-500/15', border: 'border-purple-500/30', text: 'text-purple-400', hdr: 'from-purple-600/80 to-purple-700/80' },
            };
            const c = colorMap[g.color] || colorMap.purple;
            const groupId = `speciesGroup_${g.key}`;

            return `
                <div class="rounded-2xl overflow-hidden shadow-xl border ${c.border} ${c.bg} backdrop-blur-xl">
                    <!-- Group Header -->
                    <button onclick="toggleSpeciesGroup('${groupId}')" class="w-full flex items-center justify-between px-6 py-4 bg-gradient-to-r ${c.hdr} hover:brightness-110 transition-all cursor-pointer">
                        <div class="flex items-center gap-3">
                            <span class="text-3xl">${g.icon}</span>
                            <span class="text-lg font-bold text-white uppercase tracking-wide">${g.label}</span>
                            <span class="text-xs bg-white/20 px-2 py-0.5 rounded-full text-white font-bold">${pets.length}</span>
                        </div>
                        <svg id="chevron_${groupId}" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white/70 transform transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- Collapsible Content -->
                    <div id="${groupId}" class="hidden">
                        <!-- Search Bar -->
                        <div class="px-4 pt-3 pb-2">
                            <input type="text" placeholder="Buscar por nombre de mascota o propietario..." oninput="filterSpeciesGroup('${g.key}', this.value)"
                                class="w-full bg-black/30 border border-white/10 text-white text-sm rounded-lg px-4 py-2 focus:border-emerald-500 focus:ring-1 focus:ring-emerald-500 transition-colors placeholder-gray-500">
                        </div>
                        <!-- Table -->
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm text-gray-300">
                                <thead class="bg-black/20 text-xs uppercase font-semibold ${c.text}">
                                    <tr>
                                        <th class="px-6 py-3">Mascota</th>
                                        <th class="px-6 py-3">Propietario</th>
                                        <th class="px-6 py-3">Raza</th>
                                        <th class="px-6 py-3">Detalles</th>
                                        <th class="px-6 py-3">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="tbody_${g.key}" class="divide-y divide-white/5">
                                    ${renderSpeciesRows(pets)}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    }

    function renderSpeciesRows(pets) {
        return pets.map(m => `
            <tr class="hover:bg-white/5 transition-colors cursor-pointer" onclick="openMascotaProfile(${m.id})">
                <td class="px-6 py-3 font-bold text-white">${m.nombre_mascota}</td>
                <td class="px-6 py-3">${m.nombre_propietario}</td>
                <td class="px-6 py-3 text-emerald-400 text-xs">${m.raza || 'N/D'}</td>
                <td class="px-6 py-3 truncate max-w-xs text-gray-400">${m.datos_extra || 'Paciente regular'}</td>
                <td class="px-6 py-3">
                    <button class="text-blue-400 hover:text-white px-2" onclick="event.stopPropagation(); openMascotaProfile(${m.id})">Ver</button>
                    <button class="text-red-400 hover:text-red-300 px-2" onclick="event.stopPropagation(); deleteMascota(${m.id})">Eliminar</button>
                </td>
            </tr>
        `).join('');
    }

    window.toggleSpeciesGroup = (groupId) => {
        const el = document.getElementById(groupId);
        const chevron = document.getElementById(`chevron_${groupId}`);
        if (el.classList.contains('hidden')) {
            el.classList.remove('hidden');
            chevron.classList.add('rotate-180');
        } else {
            el.classList.add('hidden');
            chevron.classList.remove('rotate-180');
        }
    };

    window.filterSpeciesGroup = (speciesKey, query) => {
        const q = query.toLowerCase().trim();
        // Determine which pets belong to this species group
        const isOther = speciesKey === '__other';
        const groupPets = cache.mascotas.filter(m => {
            if (isOther) return !SPECIES_GROUPS.find(g => g.key === m.especie);
            return m.especie === speciesKey;
        });
        const filtered = q.length === 0 ? groupPets : groupPets.filter(m =>
            m.nombre_mascota.toLowerCase().includes(q) ||
            m.nombre_propietario.toLowerCase().includes(q)
        );
        const tbody = document.getElementById(`tbody_${speciesKey}`);
        if (tbody) tbody.innerHTML = renderSpeciesRows(filtered);
    };

    // === CALENDAR STATE ===
    const CAL_HOURS_START = 7;
    const CAL_HOURS_END = 20;
    const CAL_ROW_HEIGHT = 60; // px per hour
    const DAY_NAMES = ['lun', 'mar', 'mié', 'jue', 'vie', 'sáb', 'dom'];
    const MONTH_NAMES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    let calWeekStart = getMonday(new Date());
    let miniCalMonth = new Date();

    function getMonday(d) {
        const dt = new Date(d);
        const day = dt.getDay();
        const diff = dt.getDate() - day + (day === 0 ? -6 : 1);
        dt.setDate(diff);
        dt.setHours(0,0,0,0);
        return dt;
    }

    function addDays(d, n) {
        const r = new Date(d);
        r.setDate(r.getDate() + n);
        return r;
    }

    function isSameDay(a, b) {
        return a.getFullYear() === b.getFullYear() && a.getMonth() === b.getMonth() && a.getDate() === b.getDate();
    }

    async function loadCitas() {
        try {
            const res = await fetch(`${API_URL}/api/citas`, { headers: { 'Authorization': `Bearer ${token}` } });
            cache.citas = await res.json();
        } catch (e) { console.error(e); }
    }

    async function initCalendar() {
        await loadCitas();
        renderCalendar();
        renderMiniCalendar();
    }

    window.navigateWeek = (offset) => {
        calWeekStart = addDays(calWeekStart, offset * 7);
        renderCalendar();
        renderMiniCalendar();
    };

    window.goToToday = () => {
        calWeekStart = getMonday(new Date());
        miniCalMonth = new Date();
        renderCalendar();
        renderMiniCalendar();
    };

    window.miniCalNav = (offset) => {
        miniCalMonth = new Date(miniCalMonth.getFullYear(), miniCalMonth.getMonth() + offset, 1);
        renderMiniCalendar();
    };

    window.miniCalGoToWeek = (dateStr) => {
        calWeekStart = getMonday(new Date(dateStr));
        renderCalendar();
        renderMiniCalendar();
    };

    function renderMiniCalendar() {
        const titleEl = document.getElementById('miniCalTitle');
        const daysEl = document.getElementById('miniCalDays');
        if (!titleEl || !daysEl) return;

        const year = miniCalMonth.getFullYear();
        const month = miniCalMonth.getMonth();
        titleEl.textContent = `${MONTH_NAMES[month]} ${year}`;

        const firstDay = new Date(year, month, 1);
        const lastDay = new Date(year, month + 1, 0);
        let startDow = firstDay.getDay();
        startDow = startDow === 0 ? 6 : startDow - 1; // Monday=0

        const today = new Date();
        const weekEnd = addDays(calWeekStart, 6);
        let html = '';

        // Empty cells before first day
        for (let i = 0; i < startDow; i++) html += '<span class="py-1 text-gray-700"></span>';

        for (let d = 1; d <= lastDay.getDate(); d++) {
            const dt = new Date(year, month, d);
            const isToday = isSameDay(dt, today);
            const inWeek = dt >= calWeekStart && dt <= weekEnd;
            let cls = 'py-1 rounded cursor-pointer hover:bg-white/10 transition-colors ';
            if (isToday) cls += 'bg-blue-600 text-white font-bold ';
            else if (inWeek) cls += 'bg-white/10 text-white ';
            else cls += 'text-gray-400 ';
            html += `<span class="${cls}" onclick="miniCalGoToWeek('${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}')">${d}</span>`;
        }
        daysEl.innerHTML = html;
    }

    function renderCalendar() {
        const today = new Date();
        // Week title
        const weekEnd = addDays(calWeekStart, 6);
        const titleEl = document.getElementById('calWeekTitle');
        if (titleEl) {
            const startMonth = MONTH_NAMES[calWeekStart.getMonth()];
            const endMonth = MONTH_NAMES[weekEnd.getMonth()];
            if (calWeekStart.getMonth() === weekEnd.getMonth()) {
                titleEl.textContent = `${calWeekStart.getDate()} – ${weekEnd.getDate()} ${startMonth} ${calWeekStart.getFullYear()}`;
            } else {
                titleEl.textContent = `${calWeekStart.getDate()} ${startMonth} – ${weekEnd.getDate()} ${endMonth} ${weekEnd.getFullYear()}`;
            }
        }

        // Day headers
        const headersEl = document.getElementById('calDayHeaders');
        if (headersEl) {
            let hhtml = '';
            for (let i = 0; i < 6; i++) {
                const d = addDays(calWeekStart, i);
                const isToday = isSameDay(d, today);
                hhtml += `<div class="p-3 text-center border-l border-white/5 ${isToday ? 'bg-blue-600/20' : ''}">`;
                hhtml += `<div class="text-xs uppercase font-semibold ${isToday ? 'text-blue-400' : 'text-gray-500'}">${DAY_NAMES[i]}</div>`;
                hhtml += `<div class="text-lg font-bold ${isToday ? 'text-blue-400' : 'text-white'}">${d.getDate()}</div>`;
                hhtml += `</div>`;
            }
            headersEl.innerHTML = hhtml;
        }

        // Time grid
        const gridEl = document.getElementById('calendarGrid');
        if (!gridEl) return;

        let ghtml = '<div class="relative" style="min-height: ' + ((CAL_HOURS_END - CAL_HOURS_START) * CAL_ROW_HEIGHT) + 'px;">';

        // Hour rows
        for (let h = CAL_HOURS_START; h < CAL_HOURS_END; h++) {
            const top = (h - CAL_HOURS_START) * CAL_ROW_HEIGHT;
            ghtml += `<div class="absolute left-0 right-0 grid grid-cols-[50px_repeat(6,1fr)]" style="top:${top}px; height:${CAL_ROW_HEIGHT}px;">`;
            ghtml += `<div class="text-xs text-gray-500 pr-2 text-right pt-1 select-none">${String(h).padStart(2,'0')}:00</div>`;
            for (let i = 0; i < 6; i++) {
                const d = addDays(calWeekStart, i);
                const isToday = isSameDay(d, today);
                const dateStr = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
                ghtml += `<div class="border-l border-t border-white/5 ${isToday ? 'bg-blue-600/5' : ''} cursor-pointer hover:bg-white/5 transition-colors" onclick="openCreateCitaModal('${dateStr}T${String(h).padStart(2,'0')}:00')"></div>`;
            }
            ghtml += `</div>`;
        }

        // Appointment blocks — with overlap compression
        const statusColors = {
            'pendiente': { bg: 'rgba(59,130,246,0.35)', border: '#3b82f6', text: '#bfdbfe' },
            'completada': { bg: 'rgba(16,185,129,0.35)', border: '#10b981', text: '#a7f3d0' },
            'cancelada': { bg: 'rgba(239,68,68,0.35)', border: '#ef4444', text: '#fecaca' }
        };

        // Group citas by day-column and hour slot
        const slotMap = {}; // key: "dayIdx-hour" -> [cita, ...]
        (cache.citas || []).forEach(cita => {
            const dt = new Date(cita.fecha_hora);
            for (let i = 0; i < 6; i++) {
                const dayDate = addDays(calWeekStart, i);
                if (isSameDay(dt, dayDate)) {
                    const hour = dt.getHours();
                    if (hour >= CAL_HOURS_START && hour < CAL_HOURS_END) {
                        const key = `${i}-${hour}`;
                        if (!slotMap[key]) slotMap[key] = [];
                        slotMap[key].push({ ...cita, _dayIdx: i, _hour: hour, _minutes: dt.getMinutes() });
                    }
                    break;
                }
            }
        });

        // Render each slot group
        Object.values(slotMap).forEach(group => {
            const count = group.length;
            group.forEach((cita, idx) => {
                const topPx = (cita._hour - CAL_HOURS_START) * CAL_ROW_HEIGHT + (cita._minutes / 60) * CAL_ROW_HEIGHT;
                const colors = statusColors[cita.estado] || statusColors['pendiente'];
                const colWidth = `((100% - 50px) / 6)`;
                const blockWidth = `calc(${colWidth} / ${count} - 3px)`;
                const blockLeft = `calc(50px + ${cita._dayIdx} * ${colWidth} + ${idx} * (${colWidth} / ${count}) + 2px)`;
                const blockHeight = count > 1 ? CAL_ROW_HEIGHT - 6 : CAL_ROW_HEIGHT - 4;

                ghtml += `<div class="absolute rounded-r-lg px-1.5 py-1 text-xs overflow-hidden cursor-pointer z-10 transition-all hover:z-30 hover:brightness-125 hover:scale-[1.03]" `;
                ghtml += `style="top:${topPx}px; height:${blockHeight}px; left:${blockLeft}; width:${blockWidth}; background:${colors.bg}; border-left:3px solid ${colors.border}; color:${colors.text};" `;
                ghtml += `onclick="openCitaDetail(${cita.id})" title="${cita.mascota_nombre} — ${cita.cliente_nombre}">`;
                if (count <= 2) {
                    ghtml += `<div class="font-bold truncate leading-tight" style="font-size:11px;">${cita.mascota_nombre || 'Mascota'}</div>`;
                    ghtml += `<div class="truncate opacity-75" style="font-size:10px;">${cita.cliente_nombre || ''}</div>`;
                } else {
                    // Very compressed: just name
                    ghtml += `<div class="font-bold truncate leading-tight" style="font-size:10px;">${cita.mascota_nombre || 'M'}</div>`;
                }
                ghtml += `</div>`;
            });
        });

        // Current time indicator
        if (today >= calWeekStart && today <= addDays(calWeekStart, 5)) {
            const nowHour = today.getHours();
            const nowMin = today.getMinutes();
            if (nowHour >= CAL_HOURS_START && nowHour < CAL_HOURS_END) {
                const nowTop = (nowHour - CAL_HOURS_START) * CAL_ROW_HEIGHT + (nowMin / 60) * CAL_ROW_HEIGHT;
                ghtml += `<div class="absolute h-0.5 bg-red-500 z-20" style="top:${nowTop}px; left:50px; right:0;"></div>`;
                ghtml += `<div class="absolute w-3 h-3 bg-red-500 rounded-full z-20" style="top:${nowTop - 5}px; left:47px;"></div>`;
            }
        }

        ghtml += '</div>';
        gridEl.innerHTML = ghtml;

        // Render today's visits list in the sidebar
        renderTodayVisits();
    }

    function renderTodayVisits() {
        const todayVisitsEl = document.getElementById('todayVisitsList');
        const countBadge = document.getElementById('todayVisitsCount');
        if (!todayVisitsEl) return;

        const today = new Date();
        const visits = (cache.citas || [])
            .filter(c => isSameDay(new Date(c.fecha_hora), today))
            .sort((a, b) => new Date(a.fecha_hora) - new Date(b.fecha_hora));

        // Update count badge
        if (countBadge) countBadge.textContent = visits.length;

        if (visits.length === 0) {
            todayVisitsEl.innerHTML = '<div style="text-align:center; padding:1.5rem 0;"><p style="color:#6b7280; font-size:0.875rem;">No hay citas programadas para hoy</p><p style="color:#4b5563; font-size:0.75rem; margin-top:0.25rem;">Las citas aparecerán aquí</p></div>';
            return;
        }

        const statusColorMap = { pendiente: '#3b82f6', completada: '#10b981', cancelada: '#ef4444' };

        todayVisitsEl.innerHTML = visits.map(c => {
            const dt = new Date(c.fecha_hora);
            const timeStr = `${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}`;
            const estado = c.estado || 'pendiente';
            const dotColor = statusColorMap[estado] || statusColorMap.pendiente;

            // Extract motivo (clean up doctor info)
            let motivoShort = c.motivo || 'Consulta';
            const bracketIdx = motivoShort.indexOf('[');
            if (bracketIdx > 0) motivoShort = motivoShort.substring(0, bracketIdx).trim();

            return `
                <div style="display:flex; align-items:center; gap:0.65rem; padding:0.6rem 0.75rem; border-radius:0.6rem; cursor:pointer; transition:background 0.15s; border:1px solid transparent;"
                     onmouseover="this.style.background='rgba(255,255,255,0.05)'; this.style.borderColor='rgba(255,255,255,0.08)';"
                     onmouseout="this.style.background='transparent'; this.style.borderColor='transparent';"
                     onclick="openCitaDetail(${c.id})">
                    <span style="font-size:0.7rem; font-weight:700; color:#60a5fa; background:rgba(59,130,246,0.12); padding:0.2rem 0.5rem; border-radius:0.35rem; min-width:45px; text-align:center; flex-shrink:0;">${timeStr}</span>
                    <div style="flex:1; min-width:0;">
                        <div style="font-size:0.8rem; font-weight:600; color:#e2e8f0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${c.mascota_nombre || 'Mascota'}</div>
                        <div style="font-size:0.7rem; color:#64748b; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${c.cliente_nombre || ''} · ${motivoShort}</div>
                    </div>
                    <span style="width:8px; height:8px; border-radius:50%; flex-shrink:0; background:${dotColor};"></span>
                </div>
            `;
        }).join('');
    }

    // View cita detail on click — full CRUD
    window.openCitaDetail = (citaId) => {
        const cita = cache.citas.find(c => c.id === citaId);
        if (!cita) return;
        const dt = new Date(cita.fecha_hora);
        const statusColors = {
            'pendiente': { badge: 'bg-blue-500/20 text-blue-400', dot: 'bg-blue-500' },
            'completada': { badge: 'bg-emerald-500/20 text-emerald-400', dot: 'bg-emerald-500' },
            'cancelada': { badge: 'bg-red-500/20 text-red-400', dot: 'bg-red-500' }
        };
        const sc = statusColors[cita.estado] || statusColors['pendiente'];
        const timeStr = dt.toLocaleTimeString('es-MX', { hour:'2-digit', minute:'2-digit' });
        const dateStr = dt.toLocaleDateString('es-MX', { weekday:'long', year:'numeric', month:'long', day:'numeric' });

        modalContent.innerHTML = `
            <div class="flex justify-between items-start mb-6 border-b border-white/10 pb-4">
                <div>
                    <h2 class="text-2xl font-bold text-white">Detalle de Cita</h2>
                    <p class="text-blue-400 text-sm">${dateStr}</p>
                </div>
                <button onclick="closeModal()" class="text-gray-400 hover:text-white text-xl">✕</button>
            </div>

            <!-- Info Cards -->
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div class="bg-black/20 rounded-xl p-3">
                    <div class="text-gray-500 text-xs mb-1">Mascota</div>
                    <div class="text-white font-bold">${cita.mascota_nombre || 'ND'}</div>
                </div>
                <div class="bg-black/20 rounded-xl p-3">
                    <div class="text-gray-500 text-xs mb-1">Propietario</div>
                    <div class="text-white font-bold">${cita.cliente_nombre || 'ND'}</div>
                </div>
                <div class="bg-black/20 rounded-xl p-3">
                    <div class="text-gray-500 text-xs mb-1">Hora</div>
                    <div class="text-white font-bold text-lg">${timeStr}</div>
                </div>
                <div class="bg-black/20 rounded-xl p-3">
                    <div class="text-gray-500 text-xs mb-1">Estado</div>
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full ${sc.dot}"></span>
                        <span class="px-2 py-0.5 ${sc.badge} rounded text-xs font-bold capitalize">${cita.estado}</span>
                    </div>
                </div>
            </div>

            <div class="bg-black/20 rounded-xl p-3 mb-6">
                <div class="text-gray-500 text-xs mb-1">Motivo</div>
                <div class="text-gray-300 text-sm">${cita.motivo || 'Sin motivo especificado'}</div>
            </div>

            <!-- Actions -->
            <div class="space-y-2">
                <div class="flex gap-2">
                    ${cita.estado === 'pendiente' ? `<button onclick="updateCitaEstado(${cita.id}, 'completada')" class="flex-1 bg-emerald-600 hover:bg-emerald-700 text-white py-2.5 rounded-lg text-sm font-bold transition-colors">&#10003; Completar</button>` : ''}
                    ${cita.estado === 'pendiente' ? `<button onclick="openCancelReasonDialog(${cita.id})" class="flex-1 bg-orange-600/70 hover:bg-orange-600 text-white py-2.5 rounded-lg text-sm font-bold transition-colors">&#10005; Cancelar</button>` : ''}
                </div>
                <!-- Reprogramar Section -->
                <div class="bg-black/20 rounded-xl p-3">
                    <button onclick="toggleReschedule()" id="rescheduleToggleBtn" class="w-full flex items-center justify-between text-amber-400 hover:text-amber-300 font-bold text-sm transition-colors">
                        <span class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                            Reprogramar Cita
                        </span>
                        <svg id="rescheduleChevron" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
                    </button>
                    <div id="reschedulePanel" class="hidden mt-3 space-y-3 animate-fade-in">
                        <label class="block text-xs text-gray-400">Nueva fecha y hora:</label>
                        <input type="datetime-local" id="rescheduleDateTime" 
                            value="${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}T${String(dt.getHours()).padStart(2,'0')}:${String(dt.getMinutes()).padStart(2,'0')}"
                            class="w-full bg-black/30 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:ring-2 focus:ring-amber-500 transition-all" />
                        <button onclick="rescheduleCita(${cita.id})" class="w-full bg-amber-600 hover:bg-amber-700 text-white py-2.5 rounded-lg text-sm font-bold transition-colors shadow-lg shadow-amber-500/20">
                            Confirmar Nueva Fecha
                        </button>
                    </div>
                </div>
            </div>
        `;
        modal.classList.remove('hidden');
    };

    window.updateCitaEstado = async (citaId, nuevoEstado) => {
        try {
            const res = await fetch(`${API_URL}/api/citas/${citaId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ estado: nuevoEstado })
            });
            if (res.ok) { closeModal(); await initCalendar(); }
            else alert('Error al actualizar estado');
        } catch(e) { console.error(e); }
    };

    window.toggleReschedule = () => {
        const panel = document.getElementById('reschedulePanel');
        const chevron = document.getElementById('rescheduleChevron');
        if (panel) {
            panel.classList.toggle('hidden');
            if (chevron) chevron.style.transform = panel.classList.contains('hidden') ? '' : 'rotate(180deg)';
        }
