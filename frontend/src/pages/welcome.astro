---
import Layout from '../layouts/Layout.astro';
import ReportForm from '../components/ReportForm.jsx';
---

<Layout title="Panel de Veterinaria">
    <!-- Navbar -->
    <nav class="fixed top-0 w-full z-50 bg-white/10 backdrop-blur-md border-b border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center space-x-3 cursor-pointer" id="navLogo">
                    <div class="bg-gradient-to-tr from-emerald-400 to-cyan-400 p-2 rounded-lg shadow-lg shadow-emerald-500/20">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                        </svg>
                    </div>
                    <span class="text-xl font-bold text-white tracking-wide">Veterinaria<span class="text-emerald-400">Test</span></span>
                </div>
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <p id="userRoleDisplay" class="text-xs text-emerald-400 font-semibold uppercase tracking-wider"></p>
                        <p id="userNameDisplay" class="text-sm text-gray-200 font-medium"></p>
                    </div>
                    <button id="logoutBtn" class="p-2 rounded-lg hover:bg-white/10 text-gray-300 hover:text-white transition-all" title="Cerrar Sesión">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </nav>

    <!-- Secondary Navigation Tabs -->
    <div class="fixed top-16 w-full z-40 bg-gradient-to-r from-emerald-700 to-teal-700 border-b border-white/10 shadow-lg">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-11">
                <div id="navTabs" class="flex items-center gap-1">
                    <button onclick="navigateTo('citas')" data-tab="citas" class="nav-tab nav-tab-active px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200">Citas</button>
                    <button onclick="navigateTo('clientes')" data-tab="clientes" class="nav-tab px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 text-white/70 hover:text-white hover:bg-white/10">Clientes</button>
                    <button onclick="navigateTo('mascotas')" data-tab="mascotas" class="nav-tab px-4 py-2 rounded-lg text-sm font-semibold transition-all duration-200 text-white/70 hover:text-white hover:bg-white/10">Mascotas</button>
                    <button onclick="openSettingsModal()" id="configDropdownBtn" class="nav-tab flex items-center gap-1.5 px-4 py-2 rounded-lg text-sm font-semibold text-white/70 hover:text-white hover:bg-white/10 transition-all duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><circle cx="12" cy="12" r="3" /></svg>
                        Configuraci&oacute;n
                    </button>
                </div>
                <!-- Search Bar -->
                <div class="flex items-center bg-white/10 hover:bg-white/15 rounded-full px-3 py-1.5 gap-2 transition-colors w-44">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-white/60 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                    <input type="text" id="globalSearchInput" placeholder="Buscar..." 
                        class="bg-transparent border-none text-white placeholder-white/50 text-sm focus:outline-none w-full"
                        oninput="handleGlobalSearch(this.value)" />
                </div>
            </div>
        </div>
    </div>

    <main class="pt-32 pb-12 px-4 max-w-7xl mx-auto">
        <!-- Header Dinámico (hidden - each tab already has its name) -->
        <div class="mb-0 flex justify-between items-center" style="display:none;">
            <div>
                <h1 id="pageTitle" class="text-3xl font-bold text-white mb-2">Panel Principal</h1>
                <p id="pageSubtitle" class="text-gray-400">Bienvenido a su sistema de gestión</p>
            </div>
             <div id="actionButtons">
                <!-- Injected buttons based on view -->
            </div>
        </div>

        <!-- VISTAS -->
        
        <!-- 1. DASHBOARD HOME -->
        <div id="viewDashboard" class="animate-fade-in">
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="bg-gradient-to-tr from-emerald-400 to-cyan-400 p-5 rounded-2xl shadow-lg shadow-emerald-500/20 mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
                    </svg>
                </div>
                <h2 class="text-2xl font-bold text-white mb-2">Bienvenido al Panel</h2>
                <p class="text-gray-400 max-w-md">Utiliza las opciones del menu superior para gestionar tus citas, clientes y mascotas.</p>
            </div>
        </div>

        <!-- 2. VIEW: MASCOTAS -->
        <div id="viewMascotas" class="hidden">
            <div id="mascotasGroupedContainer" class="space-y-4">
                <!-- Species groups will be dynamically injected here -->
            </div>
        </div>

        <!-- 3. VIEW: CLIENTES -->
        <div id="viewClientes" class="hidden">
            <!-- Search Bar -->
            <div class="mb-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-xl p-4 flex items-center gap-4">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="clientSearchInput" oninput="filterClientes()" placeholder="Buscar cliente por nombre o teléfono..." 
                    class="bg-transparent border-none text-white placeholder-gray-500 focus:ring-0 w-full text-sm" />
            </div>

            <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                 <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-300">
                        <thead class="bg-black/20 text-xs uppercase font-semibold text-emerald-400">
                            <tr>
                                <th class="px-6 py-4">Nombre</th>
                                <th class="px-6 py-4">Teléfono</th>
                                <th class="px-6 py-4">Email</th>
                                <th class="px-6 py-4">Mascotas</th>
                                <th class="px-6 py-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="clientesTableBody" class="divide-y divide-white/5"></tbody>
                    </table>
                </div>
            </div>
        </div>

         <!-- 4. VIEW: CITAS (Calendar) -->
        <div id="viewCitas" class="hidden">
            <div class="animate-fade-in">
                <!-- Top Navigation Bar -->
                <div class="flex items-center justify-between mb-4 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl px-4 py-3">
                    <div class="flex items-center gap-3">
                        <button onclick="goToToday()" class="text-sm bg-white/10 hover:bg-white/15 text-white px-4 py-1.5 rounded-lg transition-colors font-medium">Esta semana</button>
                        <button onclick="navigateWeek(-1)" class="p-1.5 rounded-lg hover:bg-white/10 text-gray-400 hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                        </button>
                        <button onclick="navigateWeek(1)" class="p-1.5 rounded-lg hover:bg-white/10 text-gray-400 hover:text-white transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                        </button>
                        <h2 id="calWeekTitle" class="text-lg font-bold text-white ml-2"></h2>
                    </div>
                    <!-- Legend inline -->
                    <div class="flex items-center gap-4 text-xs">
                        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-blue-500 inline-block"></span><span class="text-gray-400">Pendiente</span></div>
                        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-emerald-500 inline-block"></span><span class="text-gray-400">Completada</span></div>
                        <div class="flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-red-500 inline-block"></span><span class="text-gray-400">Cancelada</span></div>
                    </div>
                </div>

                <!-- Main Content: Left Sidebar + Calendar -->
                <div class="flex gap-4">
                    <!-- Left Sidebar: Citas de Hoy -->
                    <div style="width: 260px; flex-shrink: 0; display: flex; flex-direction: column; gap: 1rem;">
                        <!-- Citas de Hoy Card -->
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem;">
                                <div style="display: flex; align-items: center; gap: 0.5rem; font-size: 1rem; font-weight: 700; color: #fff;">
                                    <svg xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;color:#60a5fa;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                                    Citas de hoy
                                </div>
                                <span id="todayVisitsCount" style="display:inline-flex;align-items:center;justify-content:center;min-width:28px;height:28px;border-radius:50%;background:rgba(59,130,246,0.2);color:#60a5fa;font-size:0.8rem;font-weight:700;">0</span>
                            </div>
                            <div id="todayVisitsList" style="display:flex;flex-direction:column;gap:0.4rem;max-height:calc(100vh - 380px);overflow-y:auto;">
                                <!-- Injected by JS -->
                            </div>
                        </div>

                        <!-- Mini Calendar -->
                        <div style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 1rem; padding: 1.25rem;">
                            <div class="flex items-center justify-between mb-3">
                                <button onclick="miniCalNav(-1)" class="text-gray-400 hover:text-white p-1 rounded hover:bg-white/10 transition-colors">&lt;</button>
                                <span id="miniCalTitle" class="text-sm font-bold text-white"></span>
                                <button onclick="miniCalNav(1)" class="text-gray-400 hover:text-white p-1 rounded hover:bg-white/10 transition-colors">&gt;</button>
                            </div>
                            <div class="grid grid-cols-7 gap-0 text-center text-xs">
                                <span class="text-gray-500 py-1 font-semibold">L</span>
                                <span class="text-gray-500 py-1 font-semibold">M</span>
                                <span class="text-gray-500 py-1 font-semibold">X</span>
                                <span class="text-gray-500 py-1 font-semibold">J</span>
                                <span class="text-gray-500 py-1 font-semibold">V</span>
                                <span class="text-gray-500 py-1 font-semibold">S</span>
                                <span class="text-gray-500 py-1 font-semibold">D</span>
                            </div>
                            <div id="miniCalDays" class="grid grid-cols-7 gap-0 text-center text-xs"></div>
                        </div>
                    </div>

                    <!-- Main Calendar Grid -->
                    <div class="flex-1 bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                        <!-- Day Headers -->
                        <div class="grid grid-cols-[50px_repeat(6,1fr)] border-b border-white/10">
                            <div class="p-2"></div>
                            <div id="calDayHeaders" class="contents"></div>
                        </div>
                        <!-- Time Grid -->
                        <div id="calendarGrid" class="relative overflow-y-auto" style="max-height: 600px;">
                            <!-- Rows injected by JS -->
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAB Button -->
        <button id="citaFabBtn" onclick="toggleCitaDrawer()"
            style="display:none; position:fixed; bottom:2rem; right:2rem; width:56px; height:56px; border-radius:50%; background:linear-gradient(135deg,#3b82f6,#2563eb); color:white; border:none; cursor:pointer; align-items:center; justify-content:center; box-shadow:0 6px 20px rgba(37,99,235,0.4); z-index:80; transition:all 0.3s cubic-bezier(0.4,0,0.2,1);">
            <svg id="citaFabIcon" xmlns="http://www.w3.org/2000/svg" style="width:28px;height:28px;transition:transform 0.3s;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
        </button>

        <!-- Drawer Overlay -->
        <div id="citaDrawerOverlay" onclick="toggleCitaDrawer()"
            style="position:fixed; inset:0; z-index:90; background:rgba(0,0,0,0.35); backdrop-filter:blur(2px); opacity:0; pointer-events:none; transition:opacity 0.3s ease;">
        </div>

        <!-- Cita Creation Drawer -->
        <div id="citaDrawer"
            style="position:fixed; top:0; right:0; width:420px; height:100vh; background:#0f172a; border-left:1px solid rgba(255,255,255,0.08); box-shadow:-8px 0 30px rgba(0,0,0,0.4); transform:translateX(100%); transition:transform 0.35s cubic-bezier(0.4,0,0.2,1); z-index:95; display:flex; flex-direction:column; overflow:hidden;">
            <div style="display:flex; align-items:center; justify-content:space-between; padding:1.15rem 1.5rem; border-bottom:1px solid rgba(255,255,255,0.08); flex-shrink:0; background:rgba(0,0,0,0.2);">
                <h3 style="font-size:1.1rem; font-weight:700; color:white; display:flex; align-items:center; gap:0.5rem; margin:0;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;color:#60a5fa;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                    Nueva Cita
                </h3>
                <button onclick="toggleCitaDrawer()" style="padding:0.4rem; border-radius:0.5rem; background:none; border:none; color:#9ca3af; cursor:pointer; transition:all 0.15s;">
                    <svg xmlns="http://www.w3.org/2000/svg" style="width:20px;height:20px;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div id="citaDrawerBody" style="flex:1; overflow-y:auto; padding:1.25rem 1.5rem;">
                <!-- Form injected by JS -->
            </div>
        </div>



        <!-- 5. VIEW: ADMIN DASHBOARD -->
        <div id="viewAdmin" class="hidden">
             <div class="bg-white/5 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden shadow-2xl">
                 <div class="p-6 border-b border-white/10 flex justify-between items-center">
                    <h2 class="text-xl font-bold text-white">Veterinarias Registradas</h2>
                    <!-- <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm">Nueva Veterinaria</button> -->
                 </div>
                 <div class="overflow-x-auto">
                    <table class="w-full text-left text-sm text-gray-300">
                        <thead class="bg-black/20 text-xs uppercase font-semibold text-indigo-400">
                            <tr>
                                <th class="px-6 py-4">Veterinaria</th>
                                <th class="px-6 py-4">Usuario Admin</th>
                                <th class="px-6 py-4">Email</th>
                                <th class="px-6 py-4">Teléfono</th>
                                <th class="px-6 py-4">Estado</th>
                            </tr>
                        </thead>
                        <tbody id="adminTableBody" class="divide-y divide-white/5"></tbody>
                    </table>
                </div>
            </div>
        </div>

    </main>

    <!-- Modal GLOBAL -->
    <div id="globalModal" class="fixed inset-0 z-[100] hidden">
        <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modalBackdrop"></div>
        <div class="flex items-center justify-center min-h-screen px-4">
            <div id="modalContent" class="bg-gray-900 border border-white/10 rounded-2xl shadow-2xl w-full max-w-2xl relative z-10 p-6 max-h-[90vh] overflow-y-auto">
                <!-- Injected Content -->
            </div>
        </div>
    </div>

    <!-- Settings Modal (Outlook-style) -->
    <div id="settingsModal" class="settings-modal-overlay hidden">
        <div class="settings-modal animate-fade-in">
            <!-- Header -->
            <div class="settings-header">
                <h2 class="settings-header-title">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><circle cx="12" cy="12" r="3" /></svg>
                    Configuraci&oacute;n
                </h2>
                <button onclick="closeSettingsModal()" class="settings-close-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <!-- Body: Sidebar + Content -->
            <div class="settings-body">
                <!-- Sidebar -->
                <div class="settings-sidebar">
                    <button onclick="switchSettingsTab('general')" data-settings-tab="general" class="settings-sidebar-item settings-sidebar-active">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><circle cx="12" cy="12" r="3" /></svg>
                        General
                    </button>
                    <button onclick="switchSettingsTab('veterinarios')" data-settings-tab="veterinarios" class="settings-sidebar-item">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>
                        Veterinarios
                    </button>
                    <button onclick="switchSettingsTab('reportes')" data-settings-tab="reportes" class="settings-sidebar-item">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
