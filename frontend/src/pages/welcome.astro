             const pets = client?.mascotas || [];
             const mascotaContainer = document.getElementById('mascotaSelectorContainer');
             const hiddenMascotaId = document.getElementById('citaMascotaId');

             if (pets.length === 0) {
                 hiddenMascotaId.value = '';
                 mascotaContainer.innerHTML = '<p class="text-yellow-400 text-xs">⚠️ Este propietario no tiene mascotas registradas.</p>';
             } else if (pets.length === 1) {
                 // Auto-select the only pet
                 hiddenMascotaId.value = pets[0].id;
                 mascotaContainer.innerHTML = `
                     <div class="bg-emerald-500/20 border border-emerald-500/30 rounded-lg px-4 py-2 flex items-center gap-2">
                         <span class="text-emerald-300 text-sm font-medium">🐾 ${pets[0].nombre} <span class="text-gray-400 text-xs">(${pets[0].especie}${pets[0].raza ? ' · ' + pets[0].raza : ''})</span></span>
                     </div>
                 `;
             } else {
                 // Multiple pets — dropdown
                 hiddenMascotaId.value = '';
                 mascotaContainer.innerHTML = `
                     <select id="mascotaDropdown" onchange="document.getElementById('citaMascotaId').value = this.value"
                         class="bg-black/20 border border-white/10 rounded-lg px-4 py-2 text-white w-full focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors">
                         <option value="" disabled selected>Selecciona la mascota...</option>
                         ${pets.map(p => `<option value="${p.id}">🐾 ${p.nombre} (${p.especie}${p.raza ? ' · ' + p.raza : ''})</option>`).join('')}
                     </select>
                 `;
             }
         };

         window.clearOwnerSelection = () => {
             hiddenClientId.value = '';
             document.getElementById('citaMascotaId').value = '';
             ownerBadgeDiv.classList.add('hidden');
             ownerSearchInput.classList.remove('hidden');
             ownerSearchInput.value = '';
             ownerSearchInput.focus();
             // Reset pet selector
             document.getElementById('mascotaSelectorContainer').innerHTML = '<p class="text-gray-600 text-xs italic">Selecciona un propietario primero para ver sus mascotas.</p>';
         };

         // ===== INLINE CLIENT/PET CREATION LOGIC =====
         window.showInlineClientForm = () => {
             document.getElementById('ownerSearchWrapper').classList.add('hidden');
             document.getElementById('mascotasSectionWrapper').classList.add('hidden');
             document.getElementById('inlineClientFormContainer').classList.remove('hidden');
             
             // Reset form
             document.getElementById('inlineClienteNombre').value = '';
             document.getElementById('inlineClienteTelefono').value = '';
             document.getElementById('inlineMascotaNombre').value = '';
             document.getElementById('inlineMascotaEspecie').value = 'Perro';
             document.getElementById('inlineMascotaRaza').value = '';
             document.getElementById('inlineFormError').classList.add('hidden');
             document.getElementById('inlineClienteNombre').focus();
         };

         window.hideInlineClientForm = () => {
             document.getElementById('ownerSearchWrapper').classList.remove('hidden');
             document.getElementById('mascotasSectionWrapper').classList.remove('hidden');
             document.getElementById('inlineClientFormContainer').classList.add('hidden');
             document.getElementById('ownerSearchInput').focus();
         };

         window.saveInlineClientAndPet = async () => {
             const cName = document.getElementById('inlineClienteNombre').value.trim();
             const cPhone = document.getElementById('inlineClienteTelefono').value.trim();
             const mName = document.getElementById('inlineMascotaNombre').value.trim();
             const mEsp = document.getElementById('inlineMascotaEspecie').value;
             const mRaza = document.getElementById('inlineMascotaRaza').value.trim();
             const errDiv = document.getElementById('inlineFormError');
             const btn = document.getElementById('btnSaveInline');

             if (!cName || !mName) {
                 errDiv.textContent = 'El nombre del propietario y de la mascota son obligatorios.';
                 errDiv.classList.remove('hidden');
                 return;
             }

             errDiv.classList.add('hidden');
             btn.disabled = true;
             btn.innerHTML = '<span class="animate-spin inline-block mr-1">↻</span> Guardando...';

             try {
                 // 1. Create client
                 const clientRes = await fetch(`${API_URL}/api/clientes`, {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                     body: JSON.stringify({ nombre: cName, telefono: cPhone })
                 });
                 
                 if (!clientRes.ok) throw new Error('Error al crear el cliente');
                 const clientData = await clientRes.json();
                 
                 // 2. Create pet associated with this client
                 const petRes = await fetch(`${API_URL}/api/mascotas`, {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                     body: JSON.stringify({
                         cliente_id: clientData.id,
                         nombre_mascota: mName,
                         especie: mEsp,
                         raza: mRaza
                     })
                 });
                 
                 if (!petRes.ok) throw new Error('Error al crear la mascota');
                 const petData = await petRes.json();

                 // 3. Update local caches manually to avoid fetching full lists again right now
                 const newClient = { id: clientData.id, nombre: cName, telefono: cPhone, mascotas: [petData] };
                 cache.clientes.unshift(newClient); 
                 cache.mascotas.unshift(petData);
                 
                 // Update search index
                 ownerSearchData.unshift({
                     id: clientData.id,
                     nombre: cName,
                     telefono: cPhone,
                     mascotasCount: 1,
                     searchText: `${cName} ${cPhone}`.toLowerCase()
                 });

                 // 4. Hide form and auto-select
                 hideInlineClientForm();
                 
                 // Use existing selectOwner logic, but we need to pass the newly constructed client object
                 // wait, selectOwner looks it up in cache.clientes, which we just updated!
                 selectOwner(clientData.id, cName);

             } catch(err) {
                 console.error(err);
                 errDiv.textContent = 'Hubo un error de red. Detalles en consola.';
                 errDiv.classList.remove('hidden');
             } finally {
                 btn.disabled = false;
                 btn.innerHTML = 'Guardar y Seleccionar';
             }
         };

         // ===== MOTIVO CHANGE → FILTER VETS =====
         window.handleMotivoChange = (val) => {
             const customInput = document.getElementById('motivoCustomInput');
             const hidden = document.getElementById('motivoHidden');
             if (val === '__otro') {
                 customInput.classList.remove('hidden');
                 customInput.focus();
                 hidden.value = '';
             } else {
                 customInput.classList.add('hidden');
                 hidden.value = val;
             }
             // Re-render vet cards based on motivo + selected time
             updateVetCards();
         };

         // ===== DATE NAVIGATION (BUTTON-BASED) =====
         window.navigateDatePicker = (direction) => {
             const newDate = new Date(selectedDate);
             newDate.setDate(newDate.getDate() + direction);
             // Clamp to [today, today+60]
             if (newDate < today || newDate > maxDate) return;
             selectedDate = newDate;
             renderDatePicker();
         };

         function renderDatePicker() {
             const display = document.getElementById('dateDisplay');
             const prevBtn = document.getElementById('datePrevBtn');
             const nextBtn = document.getElementById('dateNextBtn');
             const dateOnlyHidden = document.getElementById('citaDateOnly');

             display.textContent = formatDateDisplay(selectedDate);
             dateOnlyHidden.value = toDateStr(selectedDate);

             // Disable prev if at today
             prevBtn.disabled = (selectedDate <= today);
             // Disable next if at max
             nextBtn.disabled = (selectedDate >= maxDate);

             // Reset time selection
             document.getElementById('citaFecha').value = '';
             document.getElementById('citaSelectedSlot').textContent = '';
             document.getElementById('citaDoctorNombre').value = '';

             // Generate time slots for this date
             generateTimeSlots(toDateStr(selectedDate));
         }

         // Override selectTimeSlot to also update vet cards
         const originalSelectTimeSlot = window.selectTimeSlot;
         window.selectTimeSlot = (dtValue) => {
             originalSelectTimeSlot(dtValue);
             updateVetCards();
         };

         // ===== VET CARDS RENDERING (FILTERED BY MOTIVO + TIME) =====
         function updateVetCards() {
             const container = document.getElementById('vetCardsContainer');
             const filterMsg = document.getElementById('vetFilterMsg');
             const hiddenDoctor = document.getElementById('citaDoctorNombre');

             // Get current motivo
             const motivoSelect = document.getElementById('motivoSelect');
             const motivoHidden = document.getElementById('motivoHidden');
             const motivoVal = motivoSelect.value === '__otro' ? (motivoHidden.value || '') : motivoSelect.value;

             // Get current datetime
             const fechaVal = document.getElementById('citaFecha')?.value || '';
             let selectedHour = null;
             if (fechaVal) {
                 const dt = new Date(fechaVal);
                 if (!isNaN(dt)) selectedHour = dt.getHours();
             }

             // If no motivo and no time selected, show placeholder
             if (!motivoVal && selectedHour === null) {
                 container.innerHTML = '<p class="col-span-2 text-gray-600 text-xs italic">Selecciona un motivo y una hora para ver los veterinarios disponibles.</p>';
                 filterMsg.textContent = '';
                 hiddenDoctor.value = '';
                 return;
             }

             // Determine required vet tipo based on motivo
             let requiredTipo = null;
             if (motivoVal) {
                 requiredTipo = MOTIVOS_GENERALES.includes(motivoVal) ? 'general' : 'especialista';
             }

             // Filter vets
             let filteredVets = VETERINARIOS.filter(v => {
                 // Filter by tipo if motivo is selected
                 if (requiredTipo && v.tipo !== requiredTipo) return false;
                 return true;
             });

             // Build filter message
             let msgParts = [];
             if (requiredTipo === 'general') msgParts.push('🩺 Mostrando veterinarios generales');
             else if (requiredTipo === 'especialista') msgParts.push('⚕️ Mostrando veterinarios especialistas');

             if (filteredVets.length === 0) {
                 container.innerHTML = '<p class="col-span-2 text-yellow-400 text-xs">No hay veterinarios disponibles para este motivo.</p>';
                 filterMsg.textContent = msgParts.join(' · ');
                 hiddenDoctor.value = '';
                 return;
             }

             // Render vet cards
             container.innerHTML = filteredVets.map(v => {
                 const turnoInfo = TURNOS[v.turno] || {};
                 const horarioText = getVetHorarioTexto(v);
                 const fotoHtml = v.foto
                     ? `<img src="${v.foto}" alt="${v.nombre}" class="w-8 h-8 rounded-full object-cover">`
                     : `<div class="w-8 h-8 rounded-full bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center text-white font-bold text-xs">${v.nombre.charAt(0)}${v.nombre.split(' ').pop().charAt(0)}</div>`;

                 // Check availability
                 const available = isVetAvailable(v, selectedHour);
                 let statusClass = '';
                 let statusText = '';
                 let cardOpacity = '1';
                 let cardCursor = 'pointer';
                 let isDisabled = false;

                 if (selectedHour === null) {
                     statusText = '';
                 } else if (available) {
                     statusText = '✅ Disponible';
                     statusClass = 'text-emerald-400 font-semibold';
                 } else {
                     statusText = selectedHour === v.descanso ? '☕ En descanso' : '🔒 Fuera de turno';
                     statusClass = 'text-red-400';
                     cardOpacity = '0.45';
                     cardCursor = 'not-allowed';
                     isDisabled = true;
                 }

                 const tipoLabel = v.tipo === 'general' ? '🩺 General' : '⚕️ Especialista';

                 return `
                 <div class="vet-card ${isDisabled ? 'vet-unavailable' : (selectedHour !== null ? 'vet-available' : 'vet-neutral')} relative rounded-xl border border-white/10 bg-black/20 p-3 cursor-pointer
                     transition-all duration-200 hover:border-emerald-500/50 select-none"
                     data-vet-id="${v.id}"
                     ${isDisabled ? 'disabled' : ''}
                     onclick="${isDisabled ? '' : `selectVet(${v.id}, '${v.nombre.replace(/'/g, "\\'")}')`}"
                     style="opacity:${cardOpacity}; cursor:${cardCursor}"
                     title="Horario: ${horarioText}">
                     <div class="flex items-center gap-2 mb-1">
                         ${fotoHtml}
                         <div class="min-w-0">
                             <div class="text-white text-xs font-bold leading-tight truncate">${v.nombre}</div>
                             <div class="text-emerald-400 text-xs truncate">${v.especialidad}</div>
                         </div>
                     </div>
                     <div class="flex items-center justify-between text-xs mt-1">
                         <span class="text-gray-500">${tipoLabel}</span>
                     </div>
                     <div class="vet-schedule text-gray-500 text-xs">🕐 ${horarioText}</div>
                     <div class="vet-status text-xs mt-1 ${statusClass}">${statusText}</div>
                     <div class="vet-check hidden absolute top-2 right-2 w-5 h-5 bg-emerald-500 rounded-full flex items-center justify-center">
                         <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                     </div>
                 </div>
                 `;
             }).join('');

             filterMsg.textContent = msgParts.join(' · ');

             // Clear doctor selection if previously selected vet is no longer visible
             const currentDoctor = hiddenDoctor.value;
             if (currentDoctor) {
                 const stillVisible = filteredVets.some(v => v.nombre === currentDoctor);
                 if (!stillVisible) {
                     hiddenDoctor.value = '';
                     document.querySelectorAll('.vet-card').forEach(c => c.classList.remove('vet-selected'));
                 }
             }
         }

         // Initialize: render the date picker and generate time slots
         renderDatePicker();

         // If a datetime was prefilled, try to auto-select the matching time slot
         if (prefillDateTime) {
             setTimeout(() => {
                 const datePart = prefillDateTime.slice(0, 10);
                 setTimeout(() => {
                     const [, timePart] = prefillDateTime.split('T');
                     if (timePart) {
                         const [hStr, mStr] = timePart.split(':');
                         const h = parseInt(hStr);
                         const m = parseInt(mStr) >= 30 ? 30 : 0;
                         const pad = (n) => String(n).padStart(2, '0');
                         const slotDt = `${datePart}T${pad(h)}:${pad(m)}`;
                         selectTimeSlot(slotDt);
                     }
                 }, 30);
             }, 50);
         }

         // ===== FORM SUBMIT =====
         document.getElementById('createCitaForm').onsubmit = async (e) => {
             e.preventDefault();
             const formData = new FormData(e.target);
             const data = Object.fromEntries(formData);
             
             if (!data.cliente_id) { alert('Selecciona un propietario'); return; }
             if (!data.mascota_id) { alert('Selecciona una mascota'); return; }
             if (!data.motivo || !data.motivo.trim()) { alert('Selecciona o escribe el motivo de la consulta'); return; }
             if (!data.fecha_hora || !data.fecha_hora.trim()) { alert('Selecciona una fecha y un horario disponible'); return; }
             if (!data.doctor_nombre || !data.doctor_nombre.trim()) { alert('Selecciona un doctor veterinario disponible'); return; }
             
             // Build motivo with doctor and optional extra data
             const datosExtra = document.getElementById('citaDatosExtra').value.trim();
             let motivoFinal = `${data.motivo} [Doctor: ${data.doctor_nombre}]`;
             if (datosExtra) {
                 motivoFinal += ` | Notas: ${datosExtra}`;
             }

             const payload = {
                 fecha_hora: new Date(data.fecha_hora).toISOString(),
                 motivo: motivoFinal,
                 mascota_id: parseInt(data.mascota_id),
                 cliente_id: parseInt(data.cliente_id) 
             };

             try {
                 const res = await fetch(`${API_URL}/api/citas`, {
                     method: 'POST',
                     headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                     body: JSON.stringify(payload)
                 });
                 if(res.ok) { closeCitaDrawer(); await initCalendar(); }
                 else alert('Error al agendar');
             } catch(err) { console.error(err); }
         };
    }
    
    // --- Admin Logic ---
    async function loadAdminData() {
        try {
            const res = await fetch(`${API_URL}/api/admin/veterinarias`, { headers: { 'Authorization': `Bearer ${token}` } });
            if (res.status === 403) {
                alert('No tienes permisos de administrador');
                return;
            }
            const data = await res.json();
            renderAdminTable(data);
        } catch (e) { console.error(e); }
    }

    function renderAdminTable(data) {
        document.getElementById('adminTableBody').innerHTML = data.map(v => `
            <tr class="hover:bg-white/5 transition-colors">
                <td class="px-6 py-4 font-bold text-white">${v.nombre_veterinaria}</td>
                <td class="px-6 py-4 text-indigo-300">@${v.username}</td>
                <td class="px-6 py-4">${v.email}</td>
                <td class="px-6 py-4">${v.telefono || 'ND'}</td>
                <td class="px-6 py-4"><span class="px-2 py-1 bg-emerald-500/20 text-emerald-400 rounded text-xs">Activo</span></td>
            </tr>
        `).join('');
    }

     // Init
    if (!token) window.location.href = '/';
    
    document.getElementById('navLogo').onclick = () => {
        // Redirect based on role
        const role = document.getElementById('userRoleDisplay').textContent;
        if (role === 'admin') navigateTo('admin');
        else navigateTo('citas');
    };

    document.getElementById('logoutBtn').onclick = () => { localStorage.removeItem('access_token'); window.location.href = '/'; };

    // Set initial user info (mock or fetch me)
    fetch(`${API_URL}/api/me`, { headers: { 'Authorization': `Bearer ${token}` } })
        .then(r => r.json())
        .then(u => {
            document.getElementById('userNameDisplay').textContent = u.username;
            document.getElementById('userRoleDisplay').textContent = u.role;
            
            // Logic for initial view
            if (u.role === 'admin') {
                navigateTo('admin');
            } else {
                navigateTo('citas');
            }
        })
        .catch(() => {
             // On error (e.g. invalid token)
             localStorage.removeItem('access_token');
             window.location.href = '/';
        });

    // --- Global Search ---
    window.handleGlobalSearch = (query) => {
        const q = query.trim().toLowerCase();
        if (!q) return;
        // Navigate to clientes and filter
        navigateTo('clientes');
        const input = document.getElementById('clientSearchInput');
        if (input) {
            input.value = query;
            filterClientes();
        }
    };

</script>
