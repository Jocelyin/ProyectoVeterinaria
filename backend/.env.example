# =====================================================
#  Configuración de Notificaciones — VeterinariaTest
# =====================================================
# Copia este archivo como .env y llena tus valores.
# NUNCA subas el archivo .env a git.

# --- Gmail (SMTP) ---
# Usa una contraseña de aplicación: https://myaccount.google.com/apppasswords
SMTP_EMAIL=tu_correo@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# (Opcional) Cambiar servidor SMTP si no usas Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- WhatsApp (Twilio) ---
# 1. Crea una cuenta en https://twilio.com
# 2. Consigue tu Account SID y Auth Token desde el Dashboard
# 3. Para PRUEBAS usa el Sandbox de WhatsApp:
#    - Ve a Messaging > Try it out > Send a WhatsApp message
#    - El número sandbox es: whatsapp:+14155238886
#    - Cada cliente debe enviar el código de unión al sandbox antes de recibir mensajes
# 4. Para PRODUCCIÓN solicita un número de WhatsApp aprobado por Meta
#
# Los teléfonos de los clientes DEBEN tener código de país (ej: +521XXXXXXXXXX para México)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
